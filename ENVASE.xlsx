name: Procesar Excel → data.json

on:
  push:
    paths:
      - 'data/*.xlsx'
      - 'data/*.xls'

jobs:
  procesar:
    runs-on: ubuntu-latest
    steps:
      - name: Descargar repositorio
        uses: actions/checkout@v4

      - name: Instalar Python y dependencias
        uses: actions/setup-python@v5
        with:
          python-version: '3.11'

      - name: Instalar librerías
        run: pip install pandas openpyxl

      - name: Convertir Excel a JSON
        run: python procesar.py

      - name: Guardar data.json en el repo
        run: |
          git config user.name "github-actions[bot]"
          git config user.email "github-actions[bot]@users.noreply.github.com"
          git add data/data.json
          git diff --staged --quiet || git commit -m "🔄 Datos actualizados $(date +'%Y-%m-%d %H:%M')"
          git push
